{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "resolveJsonModule": true,
    "strict": true,
    "isolatedModules": true,
    "noEmit": true,
    "outDir": "node_modules/.ts-dist",
    "types": ["vite/client", "node", "electron"],"paths": {
      "@/*": [
        "./src/renderer/src/*"
      ]
    }
  },
  "include": ["src", "package.json"],
  "exclude": ["src/**/*.test.ts"]
}
